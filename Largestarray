package arrays;

public class Largestarray {
    public static void main(String[] args) {
        int[] arr = {10, 25, 5, 40, 15};

        int largest = arr[0];

        for (int i = 1; i < arr.length; i++) {
            if (arr[i] > largest) {
                largest = arr[i];
            }
        }

        System.out.println("Largest Element = " + largest);
    }
}
